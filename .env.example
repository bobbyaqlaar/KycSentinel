# KYC Sentinel — tenant runtime env (copy to .env; see OPERATIONS.md §0)

# Offline/testbed mode: no keys, no infra, deterministic FakeGateway
KYC_FAKE_LLM=1

# ── Real mode (unset KYC_FAKE_LLM) ─────────────────────────────────────────
# AGENTSMITH_DIR=/path/to/AgenticFramework
# ANTHROPIC_API_KEY=            # analyst + judge routes
# GROQ_API_KEY=                 # research route
# OLLAMA_BASE_URL=http://localhost:11434   # intake (sovereign) route
# AGENT_MONTHLY_USD_CAP=5       # matches tenant.yaml — F5 fires on a batch

# Guardrail modes (framework defaults shown)
ENVIRONMENT=development
INPUT_GUARDRAIL=default
PROMPT_GUARD=default
MODERATION_HOOK=optional        # regulated tenants: required
TOOL_ALLOWLIST_STRICT=1

# ── Production backends ────────────────────────────────────────────────────
# DATABASE_URL=postgresql://...     # budget + idempotency + DLQ
# BUDGET_BACKEND=postgres
# IDEMPOTENCY_BACKEND=postgres
# TEMPORAL_ADDRESS=localhost:7233
# AGENT_PHOENIX_ENDPOINT=http://localhost:6006
# OPS_PORTAL_URL=
# OPS_PORTAL_SYNC_TOKEN=
